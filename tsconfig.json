{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@concord-consortium/accessibility-tools/hooks": ["./src/hooks/index.ts"],
      "@concord-consortium/accessibility-tools/debug": ["./src/debug/index.ts"],
      "@concord-consortium/accessibility-tools/audit": ["./src/audit/index.ts"]
    }
  },
  "include": ["src", "demo", "tests"]
}
